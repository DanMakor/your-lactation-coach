---
title: Lactation Consultant
---

<!DOCTYPE html>
<html lang="en" class="bg-white text-black">

  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/assets/styles/index.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">

    
  </head>

  <body class="font-serif">
    <header class="p-3 bg-neutral-100">
      <nav class="container mx-auto flex justify-end"> 
        <ul class="hidden md:flex gap-8 font-sans">
          <a class="font-bold"><li>Welcome</li></a>
          <a class="font-bold"><li>Services</li></a>
          <a class="font-bold"><li>About Me</li></a>
          <a class="font-bold"><li>Contact Me</li></a>
        </ul>
      <nav>

      <!-- Hamburger button (mobile only) -->
      <button id="hamburger-btn" class="md:hidden flex flex-col space-y-1 p-2 bg-transparent border-0">
        <span class="w-6 h-0.5 bg-warm-gray transition-colors"></span>
        <span class="w-6 h-0.5 bg-warm-gray transition-colors"></span>
        <span class="w-6 h-0.5 bg-warm-gray transition-colors"></span>
      </button>

      <!-- Dialog menu -->
      <dialog id="mobile-menu" class="md:hidden m-0 ml-auto h-screen max-h-none w-[80vw] max-w-[22rem] border-0 bg-white p-0 text-warm-gray shadow-lg">
          <div class="flex justify-end p-4">
            <button id="close-btn" class="text-2xl text-warm-gray hover:text-gray-800">&times;</button>
          </div>
          <nav class="px-4 pb-4">
            <ul class="space-y-4 text-center">
              <li><a href="#" class="block py-2 text-warm-gray hover:text-gray-800 transition-colors">Welcome</a></li>
              <li><a href="#" class="block py-2 text-warm-gray hover:text-gray-800 transition-colors">Services</a></li>
              <li><a href="#" class="block py-2 text-warm-gray hover:text-gray-800 transition-colors">About Me</a></li>
              <li><a href="#" class="block py-2 text-warm-gray hover:text-gray-800 transition-colors">Contact Me</a></li>
            </ul>
          </nav>
        </dialog>
    </header>

  <div class="w-full h-screen max-h-[768px] bg-cover bg-center p-4" style="background-image: {% bgImage './src/assets/images/baby-hand.jpg', 1024 %};">
    <div class="container mx-auto h-full flex flex-col justify-between">
      <div>
        <div class="w-[170px] h-auto mx-auto pt-10">
          {% image "./src/assets/images/logo.png", "Your Lactation Coach Logo", "320px", "w-full h-full" %}
        </div>

        <div class="max-w-10/12 mx-auto mt-3">
          <h1 class="leading-20 text-6xl text-center text-gray-50">Your Lactation Coach</h1>
        </div>
        <div class="text-center mt-4">
          <button class="mx-auto bg-warm-gray-light px-10 py-2 font-bold text-lg rounded-full text-gray-50">Book Now</button>
        </div>
      </div>
      <h3 class="text-center text-3xl text-gray-50 self-end">Empower - Nourish - Thrive</h3>
    </div>
  </div>

  <section class="w-full min-h-screen bg-natural px-4">
    <div class="container mx-auto">
      <h2 class="text-center text-warm-gray text-5xl leading-tight pt-14">Welcome, I'm so glad you're here</h2>
      <div class="flex flex-col lg:flex-row items-center gap-16 mt-10">
        <div class="mt-5 w-[345px] h-[375px] lg:min-w-[500px] lg:w-[500px] lg:h-[550px] rounded-tr-full rounded-tl-full border-warm-gray-light border-2 overflow-hidden mx-auto">
            {% image "./src/assets/images/breastfeeding.jpg", "Mum breastfeeding baby", "(min-width: 1280px) 640px, 320px", "object-cover object-center w-full h-full" %}
        </div>
        <div class="mt-5 font-sans text-warm-gray">
          <h1 class="font-serif text-2xl">Breastfeeding is natural, but it is not always easy.</h1>

          <p class="mt-4">Did you know that in Australia nine in ten infants (90.6%) are breastfed at birth. This means that most women want to breastfeed but six weeks later the percentage has sharply dropped. At 6 months two in five (37.5%) were exclusively breastfed. <b>It is evident that mothers need support.</b></p>

          <p class="mt-3">Please know that this is a <b>safe space</b> where you will find a <b>gentle and personalised approach</b> to support you with breastfeeding your little one. Our support is shaped around your <b>unique feeding goals</b> and parenting values. We know all too well that no two journeys are the same, and we will honour yours with <b>care, respect, and understanding.</b></p>

          <p class="mt-3">In every consultation, our focus is on <b>empowering you to reach your goal.</b></p>

          <p class="mt-3">If you are <b>pregnant</b> we would love to help you get off to a <b>good start</b> and reap the benefits.</p>

          <p class="mt-3">We are here to share <b>evidence-based knowledge, practical adjustments</b> that can bring real comfort and progress.</p>

          <p class="mt-3">Sometimes the smallest changes can have the <b>biggest impact.</b></p>

          <p class="mt-3"><b>You are not meant to struggle or cope alone.</b> Let us come alongside you, don’t wait.</p>
        </div>
        </div>
      </div>
  </section>
  <script>
      const dialog = document.getElementById('mobile-menu');
      const openBtn = document.getElementById('hamburger-btn');
      const closeBtn = document.getElementById('close-btn');

      openBtn.addEventListener('click', () => dialog.showModal());
      closeBtn.addEventListener('click', () => dialog.close());

      // Close on backdrop click
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    </script>
  </body>

</html>