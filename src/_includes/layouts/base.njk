<!DOCTYPE html>
<html lang="en" class="bg-white text-black">

  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description or 'Compassionate, evidence-based lactation support tailored to your feeding goals.' }}">
    <link rel="stylesheet" href="/assets/styles/index.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
  </head>

  <body class="font-serif flex flex-col min-h-screen">
    {% set currentUrl = page.url or '/' %}
    {% set isServicesSection = currentUrl == '/services/' or currentUrl == '/antenatal/' or currentUrl == '/postnatal/' %}
    {% set showBreadcrumbs = currentUrl == '/antenatal/' or currentUrl == '/postnatal/' %}
    {% set breadcrumbCurrentLabel = '' %}
    {% if currentUrl == '/antenatal/' %}
      {% set breadcrumbCurrentLabel = 'Antenatal' %}
    {% elif currentUrl == '/postnatal/' %}
      {% set breadcrumbCurrentLabel = 'Postnatal' %}
    {% endif %}

    <header class="bg-neutral-100 p-3">
      <div class="container mx-auto flex items-center justify-between">
        <a href="/" class="font-serif text-lg font-bold text-warm-gray transition-colors hover:opacity-70" aria-label="Your Lactation Coach — home">Your Lactation Coach</a>
        <nav aria-label="Primary navigation">
          <ul class="hidden gap-8 font-sans md:flex">
            <li class="group relative">
              <a href="/services/" class="inline-flex items-center gap-1 font-bold transition-colors {% if isServicesSection %}text-warm-gray-light underline decoration-2 underline-offset-8{% else %}text-warm-gray hover:opacity-70{% endif %}" {% if isServicesSection %}aria-current="page"{% endif %}>
                <span>Services</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" aria-hidden="true" class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.2 7.2a.75.75 0 0 1 1.06 0L10 10.94l3.74-3.74a.75.75 0 1 1 1.06 1.06l-4.27 4.27a.75.75 0 0 1-1.06 0L5.2 8.26a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
                </svg>
              </a>
              <ul class="invisible absolute left-0 top-full z-20 min-w-[12rem] rounded-2xl border border-neutral-300 bg-white p-2 pt-3 opacity-0 transition duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <li>
                  <a href="/antenatal/" class="block rounded-xl px-3 py-2 text-sm transition-colors {% if currentUrl == '/antenatal/' %}bg-natural text-warm-gray-light font-bold{% else %}text-warm-gray hover:opacity-70{% endif %}" {% if currentUrl == '/antenatal/' %}aria-current="page"{% endif %}>Antenatal Support</a>
                </li>
                <li>
                  <a href="/postnatal/" class="block rounded-xl px-3 py-2 text-sm transition-colors {% if currentUrl == '/postnatal/' %}bg-natural text-warm-gray-light font-bold{% else %}text-warm-gray hover:opacity-70{% endif %}" {% if currentUrl == '/postnatal/' %}aria-current="page"{% endif %}>Postnatal Support</a>
                </li>
              </ul>
            </li>
            <li>
              <a href="/about/" class="font-bold transition-colors {% if currentUrl == '/about/' %}text-warm-gray-light underline decoration-2 underline-offset-8{% else %}text-warm-gray hover:opacity-70{% endif %}" {% if currentUrl == '/about/' %}aria-current="page"{% endif %}>About Me</a>
            </li>
            <li><a href="/contact/" class="font-bold transition-colors {% if currentUrl == '/contact/' %}text-warm-gray-light underline decoration-2 underline-offset-8{% else %}text-warm-gray hover:opacity-70{% endif %}" {% if currentUrl == '/contact/' %}aria-current="page"{% endif %}>Contact Me</a></li>
          </ul>
        </nav>

        <button id="hamburger-btn" class="flex flex-col space-y-1 border-0 bg-transparent p-2 md:hidden" aria-controls="mobile-menu" aria-label="Open menu">
          <span class="h-0.5 w-6 bg-warm-gray transition-colors"></span>
          <span class="h-0.5 w-6 bg-warm-gray transition-colors"></span>
          <span class="h-0.5 w-6 bg-warm-gray transition-colors"></span>
        </button>
      </div>

      <dialog id="mobile-menu" class="m-0 ml-auto h-screen max-h-none w-[80vw] max-w-[22rem] border-0 bg-white p-0 text-warm-gray shadow-lg md:hidden">
        <div class="flex justify-end p-4">
          <button id="close-btn" class="text-2xl text-warm-gray hover:text-gray-800" aria-label="Close menu">&times;</button>
        </div>
        <nav class="px-4 pb-4" aria-label="Mobile navigation">
          <ul class="space-y-4 text-center">
            <li>
              <a href="/services/" class="block py-2 transition-colors {% if isServicesSection %}bg-natural rounded-lg text-warm-gray-light font-bold{% else %}text-warm-gray hover:text-gray-800{% endif %}" {% if isServicesSection %}aria-current="page"{% endif %}>Services</a>
              <ul class="mt-2 space-y-2">
                <li>
                  <a href="/antenatal/" class="block rounded-lg px-3 py-2 text-sm transition-colors {% if currentUrl == '/antenatal/' %}bg-natural text-warm-gray-light font-bold{% else %}text-warm-gray hover:bg-natural-100{% endif %}" {% if currentUrl == '/antenatal/' %}aria-current="page"{% endif %}>Antenatal Support</a>
                </li>
                <li>
                  <a href="/postnatal/" class="block rounded-lg px-3 py-2 text-sm transition-colors {% if currentUrl == '/postnatal/' %}bg-natural text-warm-gray-light font-bold{% else %}text-warm-gray hover:bg-natural-100{% endif %}" {% if currentUrl == '/postnatal/' %}aria-current="page"{% endif %}>Postnatal Support</a>
                </li>
              </ul>
            </li>
            <li>
              <a href="/about/" class="block py-2 transition-colors {% if currentUrl == '/about/' %}bg-natural rounded-lg text-warm-gray-light font-bold{% else %}text-warm-gray hover:text-gray-800{% endif %}" {% if currentUrl == '/about/' %}aria-current="page"{% endif %}>About Me</a>
            </li>
            <li><a href="/contact/" class="block py-2 transition-colors {% if currentUrl == '/contact/' %}bg-natural rounded-lg text-warm-gray-light font-bold{% else %}text-warm-gray hover:text-gray-800{% endif %}" {% if currentUrl == '/contact/' %}aria-current="page"{% endif %}>Contact Me</a></li>
          </ul>
        </nav>
      </dialog>
    </header>

    {% if showBreadcrumbs %}
      <nav class="bg-neutral-100" aria-label="Breadcrumb">
        <div class="container mx-auto py-3">
          <ol class="flex items-center gap-2 text-xs tracking-wide font-sans bold uppercase text-warm-gray-light">
            <li>
              <a href="/services/" class="transition-colors hover:text-warm-gray">Services</a>
            </li>
            <li aria-hidden="true">/</li>
            <li class="text-warm-gray" aria-current="page">{{ breadcrumbCurrentLabel }}</li>
          </ol>
        </div>
      </nav>

      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Services",
              "item": "/services/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "{{ breadcrumbCurrentLabel }}",
              "item": "{{ currentUrl }}"
            }
          ]
        }
      </script>
    {% endif %}

    {{ content | safe }}

    <footer class="mt-auto bg-neutral-100 font-sans text-warm-gray">
      <div class="container mx-auto px-4 py-10">
        <div class="grid gap-8 sm:grid-cols-3">
          <div>
            <p class="font-serif text-lg font-bold">Your Lactation Coach</p>
            <p class="mt-2 text-sm leading-6">Compassionate, evidence-based lactation support tailored to your feeding journey.</p>
          </div>
          <nav aria-label="Footer navigation">
            <p class="font-bold">Pages</p>
            <ul class="mt-2 space-y-2 text-sm">
              <li><a href="/" class="transition-colors hover:opacity-70">Home</a></li>
              <li><a href="/services/" class="transition-colors hover:opacity-70">Services</a></li>
              <li><a href="/antenatal/" class="transition-colors hover:opacity-70">Antenatal</a></li>
              <li><a href="/postnatal/" class="transition-colors hover:opacity-70">Postnatal</a></li>
              <li><a href="/about/" class="transition-colors hover:opacity-70">About Me</a></li>
              <li><a href="/contact/" class="transition-colors hover:opacity-70">Contact Me</a></li>
            </ul>
          </nav>
          <div>
            <p class="font-bold">Get in touch</p>
            <ul class="mt-2 space-y-2 text-sm">
              <li><a href="mailto:info@yourlactationcoach.com.au" class="transition-colors hover:opacity-70">info@yourlactationcoach.com.au</a></li>
              <li><a href="tel:+61438081463" class="transition-colors hover:opacity-70">+61 438 081 463</a></li>
            </ul>
            <a href="https://your-lactation-coach.au4.cliniko.com/bookings" class="mt-4 inline-block rounded-full bg-warm-gray px-6 py-2 text-sm font-bold text-white transition-colors hover:bg-warm-gray-light">Book a consultation</a>
            <div class="mt-6 flex items-center gap-4">
              <a href="https://www.nursingmidwiferyboard.gov.au/" target="_blank" rel="noreferrer">
              {% imageSmall "./src/assets/images/ahpra.png", "AHPRA registration logo", "150px", "h-auto w-[150px]" %}
              </a>

              <a href="https://iblce.org/" target="_blank" rel="noreferrer">
              {% imageSmall "./src/assets/images/ibclc.png", "IBCLC certification logo", "80px", "h-auto w-[80px]" %}
              </a>
            </div>
          </div>
        </div>
        <p class="mt-8 border-t border-warm-gray-light pt-6 text-center text-xs text-warm-gray-light">&copy; 2026 Your Lactation Coach.</p>
      </div>
    </footer>

    <script>
      const dialog = document.getElementById('mobile-menu');
      const openBtn = document.getElementById('hamburger-btn');
      const closeBtn = document.getElementById('close-btn');

      if (dialog && openBtn && closeBtn) {
        openBtn.addEventListener('click', () => dialog.showModal());
        closeBtn.addEventListener('click', () => dialog.close());

        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) dialog.close();
        });
      }
    </script>
  </body>

</html>